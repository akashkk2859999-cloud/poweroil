# Backend environment variables
# Copy to backend/.env and fill in production values

NODE_ENV=production
PORT=4000
DATABASE_URL="file:./prod.db"
FRONTEND_URL=https://your-domain.com
JWT_SECRET=your-very-long-random-secret-here-minimum-32-chars
CAMPAIGN_BASE_URL=https://your-domain.com
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
